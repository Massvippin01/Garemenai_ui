// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Review {
  id        String   @id @default(uuid())
  productId String
  author    String
  rating    Int
  text      String
  date      String
  verified  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model User {
  clerkId   String   @id // Bound explicitly to Clerk Identity Token
  email     String   @unique
  firstName String?
  lastName  String?
  // Machine Learning Physical State Parameters
  height    String?
  weight    String?
  chest     String?
  waist     String?
  hips      String?
  inseam    String?
  thigh     String?
  
  // Behavioral Gates
  hasUsedAi        Boolean  @default(false)
  interactionCount Int      @default(0)

  orders    Order[]
  createdAt DateTime @default(now())
}

model Order {
  id           String      @id @default(uuid())
  orderHash    String      @unique
  customerName String      @default("Alex Carter")
  totalAmount  Float
  riskPercent  Float       @default(0)
  carbonSaved  Float       @default(0)
  riskReasons  String      @default("Perfect size match")
  status       String      @default("CONFIRMED")
  createdAt    DateTime    @default(now())

  // Secure identity mapping (Optional to allow historical non-auth orders to remain, but bound going forward)
  clerkId      String?
  user         User?       @relation(fields: [clerkId], references: [clerkId])
  
  items        OrderItem[]
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  price     Float
  size      String
  color     String
  quantity  Int
}
