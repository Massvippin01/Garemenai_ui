# ==============================================================
# CELESTIALS.CO - PUBLIC EDGE TUNNELING CONFIG
# ==============================================================
# Instructions:
# 1. Run your ML Backends locally on Windows (start_backends.bat)
# 2. Run Ngrok/Cloudflared to expose ports 8000, 8002, 8003
# 3. Paste the generated public URLs below!
# 4. If deploying to Vercel, paste these exact keys into your Vercel Project Settings.

# Model 3: Smart Size Recommender (Port 8000)
# Default: http://localhost:8000/recommend_size
ML_RECOMMENDER_URL="https://your-ngrok-url.app/recommend_size"

# Model 3 Extra: Photo Visual CV (Port 8002) 
# Note: Has NEXT_PUBLIC prefix because it is called directly from the client browser!
# Default: http://localhost:8002/analyze
NEXT_PUBLIC_ML_PHOTO_URL="https://your-ngrok-url.app/analyze"

# Model 1: Sentiment Analysis (Port 8003)
# Default: http://localhost:8003/analyze_review
ML_SENTIMENT_URL="https://your-ngrok-url.app/analyze_review"
